#!/bin/sh
# Maintainer script for apt-transport-kyc.
#
# On purge, remove the kyc apt source we installed from postinst. On
# regular remove (without --purge) leave it alone — see prerm.

set -e

case "$1" in
    purge)
        rm -f /etc/apt/sources.list.d/kyc.list
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
